#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# shellcheck source=lib/common.sh
source "$REPO_ROOT/lib/common.sh"

main() {
  case "${1:-}" in
    ""|help|-h|--help)
      print_usage
      ;;
    *)
      die "Unknown command: ${1}"
      ;;
  esac
}

main "$@"
